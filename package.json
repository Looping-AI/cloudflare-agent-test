{
  "name": "slack-ai-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker template: AI agent with Slack integration",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "slack"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "oxfmt --write .",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc"
  },
  "dependencies": {
    "@chat-adapter/slack": "^4.30.0",
    "agents": "^0.14.5",
    "ai": "^6.0.194",
    "chat": "^4.30.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
